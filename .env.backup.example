# Configuração do script de backup — copie para .env.backup e ajuste

# Diretório onde os backups serão armazenados
BACKUP_DIR=/opt/jarvis/backups

# Número de dias de retenção (backups mais antigos são removidos automaticamente)
RETENTION_DAYS=7

# Incluir backup do volume de storage (arquivos enviados pelos usuários)?
# Pode ser grande dependendo do uso. Padrão: false
BACKUP_STORAGE=false
