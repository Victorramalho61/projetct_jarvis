# ── Supabase: Banco de Dados ──────────────────────────────────────────
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── Supabase: JWT ─────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

# ── Supabase: URLs ────────────────────────────────────────────────────
API_EXTERNAL_URL=http://SEU_IP:54321
SITE_URL=https://jarvis.voetur.com.br

# ── Microsserviços: JWT compartilhado ─────────────────────────────────
JWT_SECRET=
ALLOWED_ORIGINS=https://jarvis.voetur.com.br
FRONTEND_URL=https://jarvis.voetur.com.br

# ── Microsoft 365 / Azure AD ──────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://jarvis.voetur.com.br/api/moneypenny/auth/microsoft/callback

# ── WhatsApp (Evolution API) ──────────────────────────────────────────
WHATSAPP_API_URL=http://evolution-api:8080
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=
EVOLUTION_SERVER_URL=http://SEU_IP:8080
MONITOR_AGENT_TOKENS=token-secreto-aqui

# ── Freshservice ──────────────────────────────────────────────────────
FRESHSERVICE_API_KEY=

# ── SMTP (Office 365 — reset de senha) ────────────────────────────────
# ── SQL Server externo (ERP — gastos de tecnologia) ───────────────────────────
SQL_SERVER_HOST=
SQL_SERVER_PORT=1433
SQL_SERVER_DB=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@voetur.com.br
SMTP_PASSWORD=
SMTP_FROM=Jarvis <noreply@voetur.com.br>

# ── Realtime (secrets internos do Supabase) ───────────────────────────
REALTIME_SECRET_KEY_BASE=
REALTIME_DB_ENC_KEY=

# ── Frontend (Vite build) ─────────────────────────────────────────────
VITE_API_URL=https://jarvis.voetur.com.br

# ── GitHub (agente docs-sync) ─────────────────────────────────────────
# Token com escopo repo (contents:write) para o agente docs-sync
# Gerar em: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=
# Repositório no formato "usuario/repo" (ex: voetur/jarvis)
GITHUB_REPO=

# ── LangGraph: LLM local (Ollama) ─────────────────────────────────────
# Ollama roda como container Docker interno — sem chave externa necessária
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Após subir: docker exec -it jarvis-ollama ollama pull llama3.1:8b

# ── LangGraph: LLMs gratuitos — cascata Cerebras → Groq → Together → OpenRouter → Mistral → HF → Ollama
# Quanto mais chaves configuradas, maior a resiliência e menor a latência.

# Cerebras (MAIS RÁPIDO — recomendado configurar primeiro)
# Obter em: cloud.cerebras.ai — free tier, CS-3 chip, ~0.1s/token para Llama 70B
CEREBRAS_API_KEY=

# Groq (segundo na fila — free tier, ultrarrápido)
# Obter em: console.groq.com
GROQ_API_KEY=

# Together AI — obter em: api.together.ai (free tier)
TOGETHER_API_KEY=

# OpenRouter — agregador com modelos free, obter em: openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral — obter em: console.mistral.ai (free tier com mistral-small)
MISTRAL_API_KEY=

# HuggingFace — obter em: huggingface.co/settings/tokens (free inference API)
HUGGINGFACE_API_KEY=

# ── LangGraph: Pipelines de Orquestração ──────────────────────────────
MONITORING_INTERVAL_MINUTES=15
SECURITY_INTERVAL_MINUTES=30
CICD_INTERVAL_MINUTES=5
DBA_INTERVAL_HOURS=4
GOVERNANCE_CRON_HOUR=6
EVOLUTION_CRON_HOUR=7
EVENT_CONSUMER_POLL_SECONDS=60

# ── GitHub Actions Secrets ────────────────────────────────────────────
# SUPABASE_URL    → http://localhost:54321 (para testes CI)
# SUPABASE_KEY    → service role key
# JWT_SECRET      → mesmo JWT_SECRET acima
