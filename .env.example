# ── Supabase: Banco de Dados ──────────────────────────────────────────
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── Supabase: JWT ─────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

# ── Supabase: URLs ────────────────────────────────────────────────────
API_EXTERNAL_URL=http://SEU_IP:54321
SITE_URL=http://SEU_IP:3000

# ── Backend ───────────────────────────────────────────────────────────
JWT_SECRET=
ALLOWED_ORIGINS=http://SEU_IP:3000
FRONTEND_URL=http://SEU_IP:3000

# ── Microsoft 365 / Azure AD ──────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://SEU_IP:8000/api/moneypenny/auth/microsoft/callback

# ── WhatsApp (Evolution API) ──────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# ── Frontend (Vite build) ─────────────────────────────────────────────
VITE_API_URL=http://SEU_IP:8000

# ── GitHub Actions Secrets ────────────────────────────────────────────
# SSH_HOST        → IP do servidor
# SSH_USER        → usuário SSH
# SSH_PRIVATE_KEY → chave privada (cat ~/.ssh/id_rsa)
# SUPABASE_URL    → http://localhost:54321 (para testes CI)
# SUPABASE_KEY    → service role key
# JWT_SECRET      → mesmo que o backend
