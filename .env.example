# ── Backend ──────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>

# Origens permitidas (separadas por vírgula)
# Dev:  http://localhost:5173
# Prod: https://app.seudominio.com.br
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
VITE_API_URL=http://localhost:8000

# ── GitHub Actions Secrets ───────────────────────────────────────────
# SUPABASE_URL              → mesmo que backend
# SUPABASE_KEY              → mesmo que backend
# VITE_SUPABASE_URL         → mesmo que frontend
# VITE_SUPABASE_ANON_KEY    → mesmo que frontend
# VITE_API_URL              → URL pública do backend em produção
# ALLOWED_ORIGINS           → domínio(s) do frontend em produção
#
# VERCEL_TOKEN              → vercel.com/account/tokens
# VERCEL_ORG_ID             → Vercel > Settings > General
# VERCEL_PROJECT_ID         → Vercel > Project > Settings > General
#
# SSH_HOST                  → IP ou hostname do servidor
# SSH_USER                  → usuário SSH (ex: ubuntu)
# SSH_PRIVATE_KEY           → chave privada (cat ~/.ssh/id_rsa)
